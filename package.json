{
  "name": "sqlwhisperer",
  "version": "1.0.0",
  "description": "GP to Business Central Migration Workbench with Claude AI integration",
  "main": "dist/main.js",
  "bin": {
    "sqlw": "./dist/cli/sqlw.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "sqlw": "ts-node src/cli/sqlw.ts",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "migration",
    "business-central",
    "gp",
    "claude"
  ],
  "author": "Volt Technologies",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@azure/arm-datafactory": "^19.0.0",
    "@azure/identity": "^4.13.0",
    "@azure/identity-cache-persistence": "^1.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.volt.sqlwhisperer",
    "productName": "SQLWhisperer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
